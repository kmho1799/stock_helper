# Telegram Bot 설정
# BotFather에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 메세지를 받을 Chat ID (개인 또는 그룹)
TELEGRAM_CHAT_ID=your_chat_id_here

# 체크 주기 (분 단위, 기본 5분)
CHECK_INTERVAL_MINUTES=5

# 장 시간에만 알림 (true/false)
# true: 미국 동부 시간 9:30~16:00 에만 동작
# false: 24시간 동작
MARKET_HOURS_ONLY=true

# 알림 허용 시간에만 모니터링 실행 (true/false)
# true: 허용 시간 외에는 Telegram 전송뿐 아니라 Yahoo API 호출도 하지 않음
# false: 시간 제한 없이 동작
ALERT_DELIVERY_ONLY=true

# 알림 허용 시간 판단 기준 타임존
ALERT_DELIVERY_TIMEZONE=Asia/Seoul

# 알림 허용 시작 시각 (0~23)
ALERT_DELIVERY_START_HOUR=17

# 알림 허용 종료 시각 (0~23)
# 17 ~ 다음날 09시처럼 자정을 넘기는 구간도 가능
ALERT_DELIVERY_END_HOUR=9
